{
    "name": "psc-acme/transformer-invoice",
    "description": "Package transformer-invoice for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\TransformerInvoice\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "brick/date-time": "^0.7.1",
        "psr/event-dispatcher": "^1.0",
        "league/commonmark": "^2.0"
    },
    "require-dev": {
        "symfony/phpunit-bridge": "^7.0",
        "mockery/mockery": "^1.6",
        "behat/behat": "^3.14"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}